    "checkpoint":       "/path/to/final_trained/checkpoints/best_model.pth",
    "template_encoder": "/path/to/final_trained/onnx/template_encoder.onnx",
    "search_encoder":   "/path/to/final_trained/onnx/search_encoder.onnx",
